  "detection_algorithm": {
    "steps": [
      {
        "step": 1,
        "action": "port_scan",
        "description": "Scan common ports (5000, 8000, 8080, 9000, 18790, 50080)"
      },
      {
        "step": 2,
        "action": "http_probe",
        "description": "GET / on each open port, capture title, headers, body"
      },
      {
        "step": 3,
        "action": "pattern_match",
        "description": "Match HTTP patterns against framework signatures"
      },
      {
        "step": 4,
        "action": "api_probe",
        "description": "Probe framework-specific API endpoints for confirmation"
      },
      {
        "step": 5,
        "action": "confidence_calc",
        "description": "Calculate confidence score based on pattern matches and API responses"
      }
    ],
    "confidence_calculation": {
      "base_confidence": 0.5,
      "title_match": 0.15,
      "body_keyword_match": 0.1,
      "header_match": 0.05,
      "api_endpoint_hit": 0.1,
      "api_response_structure_match": 0.15,
      "max_confidence": 1.0,
      "detection_threshold": 0.6
    }
  },
  "notes": "Signatures compiled from official documentation, GitHub repositories, and community resources. All frameworks support containerized deployment. Test against Neo gateway at 192.168.0.245:18789 as reference implementation."
}