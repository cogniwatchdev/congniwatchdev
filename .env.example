# CogniWatch Environment Variables
# Copy this file to .env and customize for your deployment

# Admin Credentials (CHANGE THESE IN PRODUCTION!)
COGNIWATCH_ADMIN_USER=admin
COGNIWATCH_ADMIN_PASSWORD=admin123

# Web UI Configuration
COGNIWATCH_HOST=0.0.0.0
COGNIWATCH_PORT=9000
COGNIWATCH_DEBUG=false

# Secret Key (generate a random one for production: python -c "import secrets; print(secrets.token_hex(32))")
COGNIWATCH_SECRET_KEY=your-secret-key-here-change-in-production

# OpenClaw Gateway Configuration
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# Scanner Configuration
SCANNER_NETWORK=192.168.0.0/24
SCANNER_INTERVAL_HOURS=24

# Security Settings
COGNIWATCH_SECURE_COOKIES=false
COGNIWATCH_TOKEN_EXPIRY=24
