# CogniWatch Performance Configuration

# Scanner Performance
COGNIWATCH_SCAN_THREADS=500
COGNIWATCH_SCAN_TIMEOUT=0.3
COGNIWATCH_USE_ASYNC=true

# Detection Cache
COGNIWATCH_DETECTION_CACHE_SIZE=10000
COGNIWATCH_DETECTION_CACHE_TTL=300

# Database Optimization
COGNIWATCH_DB_WAL_MODE=1
COGNIWATCH_DB_CACHE_SIZE=10000
COGNIWATCH_DB_MMAP_SIZE=268435456

# API Performance
COGNIWATCH_API_COMPRESS=true
COGNIWATCH_API_CACHE_TTL=30
COGNIWATCH_API_RESPONSE_LIMIT=1000

# Memory Management
COGNIWATCH_MAX_MEMORY_MB=512
COGNIWATCH_STREAM_RESULTS=true

# Connection Pooling
COGNIWATCH_HTTP_POOL_SIZE=200
COGNIWATCH_DB_POOL_SIZE=10

# Logging (performance impact: INFO < DEBUG)
COGNIWATCH_LOG_LEVEL=INFO
