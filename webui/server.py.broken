@app.route('/api/agents')
@require_auth('read')
def api_agents():
    """API: Get all agents (from cache or fallback)"""
    # Start background scan if not running
    global scanner_thread
    
    with cache_lock:
        if scanner_thread is None or scan_cache["scan_status"] == "idle":
            scanner_thread = threading.Thread(target=run_background_scan, daemon=True)
            scanner_thread.start()
            logger.info(f"🔍 Started background agent scan (user: {g.user['user_id']})")

@app.route("/api/agents/activity")
@require_auth("read")
def api_agents_activity():
    """API: Get recent agent activity feed - DEBUG VERSION"""
    try:
        # Try importing here
        import sqlite3 as sq3
        import os
        db_path = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "data", "cogniwatch.db")
        conn = sq3.connect(db_path)
        conn.row_factory = sqlite3.Row
        c = conn.cursor()
        c.execute("SELECT id, agent_id, activity_type, tool_name, details, timestamp FROM activities ORDER BY timestamp DESC LIMIT 20")
        activities = []
        for row in c.fetchall():
            activities.append({
                "id": row["id"],
                "agent_id": row["agent_id"],
                "activity_type": row["activity_type"],
                "tool_name": row["tool_name"],
                "details": row["details"],
                "timestamp": row["timestamp"]
            })
        conn.close()
        return jsonify({"activities": activities})
    except Exception as e:
        logger.error(f"Activity feed error: {e}")
        return jsonify({"error": str(e), "db_path": db_path if 'db_path' in locals() else "unknown"}), 500
        return jsonify({
            "agents": list(scan_cache["agents"]),
            "scan_status": scan_cache["scan_status"],
            "last_scan": scan_cache["last_scan"],
            "hosts_scanned": scan_cache["hosts_scanned"],
            "total_hosts": scan_cache["total_hosts"]
        })


@app.route('/api/agents/scan')
@require_auth('scan')
def api_agents_scan():
    """API: Force a new agent scan (blocking)"""
    try:
        from scanner.network_scanner import NetworkScanner
        
        network = config.get('scanner', {}).get('network', '192.168.0.0/24')
        timeout = config.get('scanner', {}).get('timeout', 1.0)
        
        scanner = NetworkScanner(network=network, timeout=timeout)
        discovered = scanner.scan_network()
        
        agents = []
        for agent in discovered:
            agents.append({
                "id": f"{agent['framework']}-{agent['host'].replace('.', '-')}-{agent['port']}",
                "name": f"{agent['framework'].title()} @ {agent['host']}:{agent['port']}",
                "framework": agent['framework'],
                "host": agent['host'],
                "port": agent['port'],
                "model": agent.get('api_info', {}).get('model', 'unknown'),
                "persona": f"Auto-discovered {agent['framework']} agent",
                "gateway_url": f"ws://{agent['host']}:{agent['port']}",
                "discovered_at": agent['detected_at'],
                "discovery_method": "network_scan",
                "status": agent['status'],
                "confidence": agent['confidence'],
                "confidence_badge": agent['confidence_badge'],
                "evidence": agent.get('evidence', [])
            })
        
        # Update cache
        scan_cache["agents"] = agents
        scan_cache["last_scan"] = datetime.now().isoformat()
        scan_cache["scan_status"] = "complete"
        
        logger.info(f"✅ Manual scan completed by {g.user['user_id']}: {len(agents)} agents")
        return jsonify({"agents": agents, "scan_time": scan_cache["last_scan"]})
        
    except Exception as e:
        logger.error(f"Manual scan failed: {e}")
        return jsonify({"error": "Scan failed", "agents": scan_cache["agents"]}), 500


@app.route('/api/agents/<agent_id>/status')
@require_auth('read')
def api_agent_status(agent_id):
    """API: Get agent status"""
    # SECURITY: Validate agent_id input
    if not validate_agent_id(agent_id):
        return jsonify({'error': 'Invalid agent ID format'}), 400
    
    if tracker:
        status = tracker.get_agent_status(agent_id)
        # SECURITY: Sanitize output
        if 'model' in status:
            status['model'] = sanitize_output(status.get('model', ''))
        return jsonify(status)
    else:
        return jsonify({"error": "Gateway not connected"}), 503


    """API: Get recent agent activity feed"""
    try:
        conn = sqlite3.connect(os.path.join(os.path.dirname(__file__), '..', 'data', 'cogniwatch.db'))
        conn.row_factory = sqlite3.Row
        c = conn.cursor()
        
        # Get recent activities
        c.execute("""
            SELECT id, agent_id, activity_type, description, timestamp, success, metadata
            FROM activities
            ORDER BY timestamp DESC
            LIMIT 20
        """)
        
        activities = []
        for row in c.fetchall():
            activities.append({
                "id": row["id"],
                "agent_id": row["agent_id"],
                "activity_type": row["activity_type"],
                "description": row["description"],
                "timestamp": row["timestamp"],
                "success": bool(row["success"]),
                "metadata": row["metadata"]
            })
        
        conn.close()
        return jsonify({"activities": activities})
        
    except Exception as e:
        logger.error(f"Activity feed error: {e}")
        return jsonify({"error": str(e)}), 500
